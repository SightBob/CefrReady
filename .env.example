# ─── Database (Neon - free PostgreSQL) ───────────────────────────────────────
# สมัครที่ https://neon.tech → copy connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/cefr_ready?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"

# สร้างด้วย: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# URL ของเว็บ (ไม่มี trailing slash)
NEXTAUTH_URL="https://your-project.vercel.app"

# ─── Cloudflare R2 (free audio storage) ──────────────────────────────────────
# สมัครที่ https://dash.cloudflare.com → R2 → Create bucket
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="cefr-ready-audio"
# เปิด Public access บน R2 bucket แล้ว copy URL
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"
